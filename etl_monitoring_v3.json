{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "annotations": { "list": [] },
  "description": "ETL Pipeline Monitoring - Unilever Data Pipeline",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Pipeline Health Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 95 }] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Success Rate (30d)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE status = 'success') / NULLIF(COUNT(*), 0), 1) AS value FROM etl_log WHERE start_time >= NOW() - INTERVAL '30 days'", "format": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 6 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Failed Runs (30d)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM etl_log WHERE status = 'failed' AND start_time >= NOW() - INTERVAL '30 days'", "format": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 420 }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Avg Run Duration (7d)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM (end_time - start_time)))) AS value FROM etl_log WHERE status = 'success' AND start_time >= NOW() - INTERVAL '7 days'", "format": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Records Loaded (Last Run)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COALESCE(records_facts, 0) AS value FROM etl_log WHERE status = 'success' ORDER BY start_time DESC LIMIT 1", "format": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 25 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Quality Issues (30d)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COALESCE(SUM(dql.issue_count), 0) AS value FROM data_quality_log dql JOIN etl_log el ON dql.run_id = el.run_id WHERE el.start_time >= NOW() - INTERVAL '30 days'", "format": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Total Runs (All Time)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM etl_log", "format": "table", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Pipeline Run History",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed_runs" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "success_runs" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Daily Runs - Success vs Failed",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT DATE_TRUNC('day', start_time) AS time, COUNT(*) FILTER (WHERE status = 'success') AS success_runs, COUNT(*) FILTER (WHERE status = 'failed') AS failed_runs FROM etl_log WHERE start_time BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1", "format": "time_series", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 8,
      "options": { "pieType": "pie", "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Run Status Distribution (30d)",
      "type": "piechart",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT status, COUNT(*) AS count FROM etl_log WHERE start_time >= NOW() - INTERVAL '30 days' GROUP BY status", "format": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 9,
      "title": "Records Loaded Per Day (fact_sales)",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT DATE_TRUNC('day', start_time) AS time, SUM(records_facts) AS records_facts FROM etl_log WHERE start_time BETWEEN $__timeFrom() AND $__timeTo() AND status = 'success' GROUP BY 1 ORDER BY 1", "format": "time_series", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 10,
      "title": "Run Duration Over Time",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT DATE_TRUNC('day', start_time) AS time, AVG(EXTRACT(EPOCH FROM (end_time - start_time))) AS avg_duration_s, MAX(EXTRACT(EPOCH FROM (end_time - start_time))) AS max_duration_s FROM etl_log WHERE start_time BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1", "format": "time_series", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Records Loaded Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 11,
      "title": "Records Loaded by Type Per Day",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT DATE_TRUNC('day', start_time) AS time, SUM(records_facts) AS facts, SUM(records_customers) AS customers, SUM(records_products) AS products, SUM(records_dates) AS dates FROM etl_log WHERE start_time BETWEEN $__timeFrom() AND $__timeTo() AND status = 'success' GROUP BY 1 ORDER BY 1", "format": "time_series", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Data Quality Monitoring",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 32 },
      "id": 12,
      "title": "Quality Issues Over Time by Check Type",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT DATE_TRUNC('day', el.start_time) AS time, dql.check_type, SUM(dql.issue_count) AS total_issues FROM data_quality_log dql JOIN etl_log el ON dql.run_id = el.run_id WHERE el.start_time BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1, 2 ORDER BY 1", "format": "time_series", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "title": "Issues by Table (30d)",
      "type": "bargauge",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT dql.table_name, SUM(dql.issue_count) AS total_issues FROM data_quality_log dql JOIN etl_log el ON dql.run_id = el.run_id WHERE el.start_time >= NOW() - INTERVAL '30 days' GROUP BY dql.table_name ORDER BY total_issues DESC", "format": "table", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Recent Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "success": { "color": "green", "index": 0 } } },
                { "type": "value", "options": { "failed":  { "color": "red",   "index": 1 } } }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "records_quality_issues" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "id": 14,
      "options": { "sortBy": [{ "displayName": "start_time", "desc": true }] },
      "title": "Recent ETL Run Logs",
      "type": "table",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT run_id, start_time, end_time, status, records_facts, records_customers, records_products, records_dates, records_quality_issues, error_message FROM etl_log ORDER BY start_time DESC LIMIT 100", "format": "table", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "issue_count" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 51 },
      "id": 15,
      "title": "Recent Data Quality Check Results",
      "type": "table",
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT dql.log_id, el.start_time AS run_time, dql.table_name, dql.check_type, dql.issue_count, dql.issue_description FROM data_quality_log dql JOIN etl_log el ON dql.run_id = el.run_id ORDER BY el.start_time DESC LIMIT 100", "format": "table", "refId": "A" }]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["etl", "monitoring", "unilever"],
  "time": { "from": "now-2y", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ETL Monitoring",
  "uid": "etl-monitoring-v3",
  "version": 1
}
