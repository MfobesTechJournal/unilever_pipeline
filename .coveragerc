[run]
source = .
branch = True
omit =
    */tests/*
    */venv/*
    */site-packages/*
    setup.py
    */__pycache__/*
    */htmlcov/*
    */.pytest_cache/*
    */migrations/*
    conftest.py

[report]
precision = 2
show_missing = True
skip_covered = False
skip_empty = True
ignore_errors = True
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == '__main__':
    raise AssertionError
    raise NotImplementedError
    if 0:
    if False:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    def __str__
    except ImportError:
    except ModuleNotFoundError:
    @overload
    class .*\(Protocol\)
    ^\s*\.\.\.$
    ^\s*pass$

[html]
directory = htmlcov
title = Code Coverage Report
